generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// Enum representing the various stages of the user onboarding process.
enum OnboardingStep {
  /// Initial stage after account creation.
  SIGNUP
  /// Email has been verified.
  EMAIL_VERIFIED
  /// Basic profile information completed.
  BASIC_INFO
  /// Bank Verification Number provided and verified.
  BVN
  /// Identity document uploaded.
  IDENTITY
  /// Selfie for identity verification uploaded.
  SELFIE
  /// Residential address provided.
  ADDRESS
  /// All onboarding steps completed.
  COMPLETED
}

/// Enum representing the status of KYC (Know Your Customer) verification.
enum KycStatus {
  /// Verification is in progress.
  PENDING
  /// Verification successfully completed.
  VERIFIED
  /// Verification rejected.
  REJECTED
}

/// Represents a user within the XBanka system.
model User {
  /// Unique identifier (UUID).
  id                         String         @id @default(uuid())
  /// User's email address (unique).
  email                      String         @unique
  /// Hashed password (null for Google OAuth users).
  password                   String?
  /// Unique Google OAuth ID.
  googleId                   String?        @unique
  /// Whether the user's email has been verified.
  isEmailVerified            Boolean        @default(false)
  /// Token used for email verification.
  verificationToken          String?
  /// Expiration timestamp for the verification token.
  verificationTokenExpiresAt DateTime?
  /// Current progress in the onboarding journey.
  currentStep                OnboardingStep @default(SIGNUP)
  /// Unique referral code for the user.
  referralCode               String?        @unique
  /// The ID of the user who referred this user.
  referredBy                 String?
  /// Timestamp of account creation.
  createdAt                  DateTime       @default(now())
  /// Timestamp of the last profile update.
  updatedAt                  DateTime       @updatedAt
  /// Hashed 4-digit transaction PIN.
  transactionPin             String?
  /// Whether 2FA is enabled for this user.
  isTwoFactorEnabled         Boolean        @default(false)
  /// Secret for TOTP-based 2FA.
  twoFactorSecret            String?
  /// Temporary OTP for sensitive security actions.
  securityOtp                String?
  /// Expiration for the security OTP.
  securityOtpExpiresAt       DateTime?

  /// One-to-one relation with the user's profile.
  profile        Profile?
  /// One-to-one relation with the user's KYC record.
  kyc            KycRecord?
  /// One-to-many relation with the user's wallets.
  wallets        Wallet[]
  /// One-to-many relation with the user's linked bank accounts.
  banks          BankDetail[]
  /// One-to-many relation with the user's transactions.
  transactions   Transaction[]
  /// One-to-many relation with the user's gift card trades.
  giftCardTrades GiftCardTrade[]
  /// One-to-many relation with the user's registered devices.
  devices        Device[]
  /// One-to-many relation with the user's active/past sessions.
  sessions       Session[]
  /// Internal records of conversion quotes.
  conversionQuotes ConversionQuote[]
  /// Direct Debit Mandates.
  directDebitMandates DirectDebitMandate[]
  /// Saved Cards.
  savedCards     SavedCard[]
}

/// Enum representing the type of wallet.
enum WalletType {
  /// Fiat currency wallet (e.g., NGN).
  FIAT
  /// Cryptocurrency wallet (e.g., USDT, BTC).
  CRYPTO
}

/// Represents a financial wallet for a specific currency.
model Wallet {
  /// Unique identifier (UUID).
  id        String     @id @default(uuid())
  /// ID of the user who owns the wallet.
  userId    String
  /// Relation to the User model.
  user      User       @relation(fields: [userId], references: [id])
  /// Wallet currency (e.g., NGN, USDT, BTC).
  currency  String
  /// Current balance in the wallet.
  balance   Float      @default(0)
  /// Type of wallet (FIAT or CRYPTO).
  type      WalletType @default(FIAT)
  /// Timestamp when the wallet was created.
  createdAt DateTime   @default(now())
  /// Timestamp of the last balance update.
  updatedAt DateTime   @updatedAt

  /// Provider-specific addresses or accounts for this wallet.
  addresses WalletAddress[]

  /// Ensure a user has only one wallet per currency.
  @@unique([userId, currency])
  /// Index for faster user-based wallet lookups.
  @@index([userId])
}

/// Stores provider-specific addresses or account details for a wallet.
model WalletAddress {
  /// Unique identifier (UUID).
  id          String   @id @default(uuid())
  /// ID of the parent wallet.
  walletId    String
  /// Relation to the Wallet model.
  wallet      Wallet   @relation(fields: [walletId], references: [id])
  /// The service provider (e.g., OBIEX).
  provider    String
  /// Optional reference ID from the provider.
  providerRef String?
  /// For crypto: the network (e.g., ERC20, TRC20, SOL).
  network     String?
  /// For crypto: the wallet address; For fiat: the account number.
  address     String?
  /// For fiat: the name on the account.
  accountName String?
  /// For fiat: the name of the bank.
  bankName    String?
  /// For fiat: the bank's unique code.
  bankCode    String?
  /// Optional memo or destination tag for crypto networks that require it.
  memo        String?
  /// Timestamp when the address was generated.
  createdAt   DateTime @default(now())
  /// Timestamp of the last update.
  updatedAt   DateTime @updatedAt

  /// Ensure a wallet has only one address per provider and network.
  @@unique([walletId, provider, network])
  /// Index for faster wallet-based address lookups.
  @@index([walletId])
}

/// Stores banking details for user withdrawals.
model BankDetail {
  /// Unique identifier (UUID).
  id            String   @id @default(uuid())
  /// ID of the user who owns these bank details.
  userId        String
  /// Relation to the User model.
  user          User     @relation(fields: [userId], references: [id])
  /// Name of the bank (e.g., GTBank).
  bankName      String
  /// The bank account number.
  accountNumber String
  /// The name registered with the bank account.
  accountName   String
  /// Whether the bank account has been verified.
  isVerified    Boolean  @default(false)
  /// Timestamp when the bank detail was added.
  createdAt     DateTime @default(now())
  /// Timestamp of the last update.
  updatedAt     DateTime @updatedAt

  /// Index for faster bank detail lookups per user.
  @@index([userId])
}

/// Types of transactions available in the system.
enum TransactionType {
  /// Funding the wallet.
  DEPOSIT
  /// Withdrawing funds from the wallet.
  WITHDRAWAL
  /// Receiving funds from another user.
  TRANSFER_IN
  /// Sending funds to another user.
  TRANSFER_OUT
  /// Converting between currencies.
  CONVERSION
}

/// Possible statuses for a transaction.
enum TransactionStatus {
  /// Transaction is being processed.
  PENDING
  /// Transaction completed successfully.
  COMPLETED
  /// Transaction failed.
  FAILED
}

/// Records all financial movements within the system.
model Transaction {
  /// Unique identifier (UUID).
  id        String            @id @default(uuid())
  /// ID of the user performing the transaction.
  userId    String
  /// Relation to the User model.
  user      User              @relation(fields: [userId], references: [id])
  /// Type of transaction.
  type      TransactionType
  /// Current status of the transaction.
  status    TransactionStatus @default(PENDING)
  /// The transaction amount.
  amount    Float
  /// The currency of the transaction.
  currency  String
  /// Unique external or internal reference ID.
  reference String            @unique
  /// Optional note or description for the transaction.
  note      String?
  /// Extra metadata stored as a JSON string.
  metadata  String?
  /// Timestamp when the transaction occurred.
  createdAt DateTime          @default(now())
  /// Timestamp of the last status update.
  updatedAt DateTime          @updatedAt

  /// Index for faster user-based transaction history lookups.
  @@index([userId])
  /// Index for filtering transactions by type.
  @@index([type])
  /// Index for filtering transactions by status.
  @@index([status])
}

/// Extended personal profile information for a user.
model Profile {
  /// Unique identifier (UUID).
  id          String    @id @default(uuid())
  /// ID of the user this profile belongs to.
  userId      String    @unique
  /// Relation to the User model.
  user        User      @relation(fields: [userId], references: [id])
  /// User's legal first name.
  firstName   String?
  /// User's legal last name.
  lastName    String?
  /// User's date of birth.
  dateOfBirth DateTime?
  /// User's unique phone number.
  phoneNumber String?   @unique
  /// User's gender.
  gender      String?
  /// User's country of residence.
  country     String?
  /// User's state of residence.
  state       String?
  /// URL to the user's avatar/profile picture.
  avatarUrl   String?
  /// Timestamp when the profile was created.
  createdAt   DateTime  @default(now())
  /// Timestamp of the last profile update.
  updatedAt   DateTime  @updatedAt
}

/// Stores identity verification records for a user.
model KycRecord {
  /// Unique identifier (UUID).
  id                  String    @id @default(uuid())
  /// ID of the user this KYC record belongs to.
  userId              String    @unique
  /// Relation to the User model.
  user                User      @relation(fields: [userId], references: [id])
  /// Bank Verification Number (unique).
  bvn                 String?   @unique
  /// Whether the BVN has been verified.
  bvnVerified         Boolean   @default(false)
  /// Type of identity document provided.
  idType              String?
  /// The number on the identity document.
  idNumber            String?
  /// URL to the uploaded ID document image.
  idImageUrl          String?
  /// URL to the uploaded identity verification selfie.
  selfieUrl           String?
  /// Verification status of the ID document.
  idStatus            KycStatus @default(PENDING)
  /// User's residential address.
  address             String?
  /// Residential address landmark.
  addressLandmark     String?
  /// Type of document used for proof of address.
  addressDocumentType String?
  /// URL to the proof of address document.
  proofOfAddress      String?
  /// Verification status of the address.
  addressStatus       KycStatus @default(PENDING)
  /// Encrypted JSON response from the external verification provider.
  bvnResponse         String?
  /// Timestamp when the KYC was fully verified.
  verifiedAt          DateTime?
  /// Timestamp when the record was created.
  createdAt           DateTime  @default(now())
  /// Timestamp of the last update.
  updatedAt           DateTime  @updatedAt
}

/// Represents a category of gift card (e.g., ECODE, PHYSICAL).
model GiftCardCategory {
  /// Unique identifier (UUID).
  id        String   @id @default(uuid())
  /// Name of the category.
  name      String   @unique
  /// Whether this category is currently active.
  isActive  Boolean  @default(true)
  /// Timestamp of creation.
  createdAt DateTime @default(now())
  /// Timestamp of update.
  updatedAt DateTime @updatedAt

  /// One-to-many relation with variants of this category.
  variants GiftCardVariant[]
  /// One-to-many relation with trades in this category.
  trades   GiftCardTrade[]
}

/// Represents a region for gift cards (e.g., USA, UK, NG).
model GiftCardRegion {
  /// Unique identifier (UUID).
  id        String   @id @default(uuid())
  /// Name of the region.
  name      String   @unique
  /// Whether this region is currently active.
  isActive  Boolean  @default(true)
  /// Timestamp of creation.
  createdAt DateTime @default(now())
  /// Timestamp of update.
  updatedAt DateTime @updatedAt

  /// One-to-many relation with variants in this region.
  variants GiftCardVariant[]
  /// One-to-many relation with trades in this region.
  trades   GiftCardTrade[]
}

/// Possible statuses for a gift card trade.
enum TradeStatus {
  /// Trade is being reviewed.
  PENDING
  /// Trade completed successfully.
  SUCCESS
  /// Trade failed or was rejected.
  FAILED
}

/// Represents a gift card brand available for trading (e.g., Apple, Amazon).
model GiftCard {
  /// Unique identifier (UUID).
  id        String   @id @default(uuid())
  /// Name of the gift card brand.
  name      String   @unique
  /// URL to the logo of the brand.
  logoUrl   String?
  /// Whether the brand is active on the platform.
  isActive  Boolean  @default(true)
  /// Timestamp when added.
  createdAt DateTime @default(now())
  /// Timestamp of last update.
  updatedAt DateTime @updatedAt

  /// One-to-many relation with specific variants of this card.
  variants GiftCardVariant[]
  /// One-to-many relation with trades for this card.
  trades   GiftCardTrade[]
}

/// Represents a specific combination of brand, category, and region.
model GiftCardVariant {
  /// Unique identifier (UUID).
  id         String           @id @default(uuid())
  /// ID of the parent gift card brand.
  cardId     String
  /// Relation to GiftCard.
  card       GiftCard         @relation(fields: [cardId], references: [id])
  /// ID of the category.
  categoryId String
  /// Relation to GiftCardCategory.
  category   GiftCardCategory @relation(fields: [categoryId], references: [id])
  /// ID of the region.
  regionId   String
  /// Relation to GiftCardRegion.
  region     GiftCardRegion   @relation(fields: [regionId], references: [id])

  /// Current exchange rate for this specific variant (NGN per 1 USD).
  rate        Float   @default(0)
  /// Daily percentage change in rate.
  dailyChange Float   @default(0)
  /// Whether this specific variant is active for trading.
  isActive    Boolean @default(true)

  /// Timestamp of creation.
  createdAt DateTime @default(now())
  /// Timestamp of update.
  updatedAt DateTime @updatedAt

  /// One-to-many relation with trades for this specific variant.
  trades GiftCardTrade[]

  /// Ensure uniqueness of variant combinations.
  @@unique([cardId, categoryId, regionId])
  @@index([cardId])
  @@index([categoryId])
  @@index([regionId])
}

/// Records all gift card sell transactions.
model GiftCardTrade {
  /// Unique identifier (UUID).
  id         String           @id @default(uuid())
  /// ID of the user performing the trade.
  userId     String
  /// Relation to the User model.
  user       User             @relation(fields: [userId], references: [id])
  /// ID of the gift card brand being traded.
  cardId     String
  /// Relation to the GiftCard model.
  card       GiftCard         @relation(fields: [cardId], references: [id])
  /// ID of the specific variant.
  variantId  String
  /// Relation to the variant.
  variant    GiftCardVariant  @relation(fields: [variantId], references: [id])
  /// ID of the category.
  categoryId String
  /// Relation to category.
  category   GiftCardCategory @relation(fields: [categoryId], references: [id])
  /// ID of the region.
  regionId   String
  /// Relation to region.
  region     GiftCardRegion   @relation(fields: [regionId], references: [id])

  /// The amount in USD.
  amount    Float       @default(0)
  /// The estimated payout in NGN.
  payout    Float       @default(0)
  /// The actual gift card code (for E-CODE).
  code      String?
  /// URL to the uploaded screenshot/proof.
  imageUrl  String?
  /// Current status of the trade.
  status    TradeStatus @default(PENDING)
  /// Timestamp when the trade was initiated.
  createdAt DateTime    @default(now())
  /// Timestamp of the last status update.
  updatedAt DateTime    @updatedAt

  /// Indexes for faster lookups.
  @@index([userId])
  @@index([cardId])
  @@index([variantId])
  @@index([status])
}

/// Represents a device used by a user.
model Device {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  deviceId  String // Client-side generated unique ID
  name      String? // e.g., "Samsung S21"
  type      String? // e.g., "MOBILE", "WEB"
  isTrusted Boolean @default(false)

  // For OTP verification
  verificationToken          String?
  verificationTokenExpiresAt DateTime?

  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessions Session[]

  @@unique([userId, deviceId])
  @@index([userId])
}

/// Represents an active or past user session.
model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  deviceId     String?
  device       Device?  @relation(fields: [deviceId], references: [id])
  ipAddress    String?
  userAgent    String?
  location     String?
  isRevoked    Boolean  @default(false)
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
}

/// Enum representing the type of fee calculation.
enum FeeType {
  /// A flat amount added to the transaction.
  FIXED
  /// A percentage of the transaction amount.
  PERCENTAGE
}

/// Stores administrative fee configurations for currency conversions.
model RateConfiguration {
  id              String   @id @default(uuid())
  /// The currency being converted from (e.g., USDT).
  sourceCurrency  String
  /// The currency being converted to (e.g., NGN).
  targetCurrency  String
  /// The type of fee (FIXED or PERCENTAGE).
  feeType         FeeType  @default(PERCENTAGE)
  /// The value of the fee (e.g., 1.5 for 1.5% or 500 for a fixed 500 NGN).
  feeValue        Float    @default(0)
  /// Whether this configuration is currently active.
  isActive        Boolean  @default(true)
  /// Timestamp of creation.
  createdAt       DateTime @default(now())
  /// Timestamp of last update.
  updatedAt       DateTime @updatedAt

  /// Ensure a unique configuration per currency pair.
  @@unique([sourceCurrency, targetCurrency])
}

/// Stores internal records of conversion quotes to hide provider IDs and for logging.
model ConversionQuote {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  /// The original quote ID from the provider (Obiex).
  obiexQuoteId    String
  sourceCurrency  String
  targetCurrency  String
  sourceAmount    Float
  rate            Float
  grossPayout     Float
  adminFee        Float
  netPayout       Float
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([userId])
}

/// Stores direct debit mandates for recurring or direct bank charges.
model DirectDebitMandate {
  /// Unique identifier (UUID).
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  /// The provider handling the mandate (e.g., PAYSTACK).
  provider          String   @default("PAYSTACK")
  /// The authorization code returned the provider.
  authorizationCode String?
  /// Internal reference used during authorization initialization.
  reference         String   @unique
  bank              String?
  accountName       String?
  last4             String?
  expMonth          Int?
  expYear           Int?
  channel           String?
  /// Status of the mandate: PENDING, ACTIVE, INACTIVE.
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// Stores tokenized cards for 1-click funding.
model SavedCard {
  /// Unique identifier (UUID).
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  /// The authorization code to charge the card.
  authorizationCode String
  cardType          String?
  last4             String?
  expMonth          String?
  expYear           String?
  bank              String?
  countryCode       String?
  brand             String?
  reusable          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

/// Stores real-time market data for cryptocurrencies from a public aggregate feed.
model CryptoMarketData {
  id               String   @id @default(uuid())
  symbol           String   @unique // e.g., BTC, ETH, USDT
  name             String   // e.g., Bitcoin, Ethereum, Tether
  priceUsd         Float    // Current price in USD
  changePercent24h Float    // 24-hour percentage change
  rank             Int?     // Market cap rank
  lastUpdated      DateTime @updatedAt

  @@index([symbol])
}
